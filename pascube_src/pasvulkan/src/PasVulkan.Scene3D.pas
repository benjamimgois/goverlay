    fData.Dispersion.Active:=true;
    fData.Dispersion.Dispersion:=TPasJSON.GetNumber(JSONObject.Properties['dispersion'],0.0);
   end;
  end;

  begin
   LoadHologramFromJSON(aSourceMaterial.Extensions.Properties['PASVULKAN_hologram']);
