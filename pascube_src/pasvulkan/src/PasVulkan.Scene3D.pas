 procedure ProcessVector3(out aVector3:TpvVector3;
                          const aAnimationChannel:TpvScene3D.TGroup.TAnimation.TChannel;
                          const aTimeIndex0:TpvSizeInt;
                          const aTimeIndex1:TpvSizeInt;
