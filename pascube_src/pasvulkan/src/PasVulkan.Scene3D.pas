var Group:TGroup;
begin
 for Group in fGroups do begin
  Group.StoreAnimationStates;
 end;
end;

procedure TpvScene3D.InterpolateAnimationStates(const aAlpha:TpvDouble);
var Group:TGroup;
begin
 for Group in fGroups do begin
  Group.InterpolateAnimationStates(aAlpha);
 end;
