  try
   if fUploaded then begin
    try
     if not fHeadless then begin
//    FreeAndNil(fVulkanIndexBuffer);
     end;
    finally
     fUploaded:=false;
    end;
   end;
  finally
   fLock.Release;
  end;
 end;
end;

