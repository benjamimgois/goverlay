    end else begin
     aVector2:=aAnimationChannel.fOutputVector2Array[aTimeIndex0];
    end;
   end;
   TpvScene3D.TGroup.TAnimation.TChannel.TInterpolation.CubicSpline:begin
    SqrFactor:=sqr(aFactor);
