 fNewImageMap:=TpvScene3D.TImages.Create;
 fNewImageMap.OwnsObjects:=false;

 fNewImages:=TpvScene3D.TImages.Create;
 fNewImages.OwnsObjects:=false;

 fNewSamplerMap:=TpvScene3D.TSamplers.Create;
