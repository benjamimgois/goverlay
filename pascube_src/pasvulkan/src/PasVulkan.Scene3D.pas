  end else begin
   CanUpdate:=true;
  end;
  IsActive:=CanUpdate;
 end else begin
  CanUpdate:=fActive;
 end;

 if aInFlightFrameIndex>=0 then begin

  fActives[aInFlightFrameIndex]:=IsActive;

