  begin
   JSONItem:=aSourceMaterial.Extensions.Properties['KHR_materials_anisotropy'];
   if assigned(JSONItem) and (JSONItem is TPasJSONItemObject) then begin
    JSONObject:=TPasJSONItemObject(JSONItem);
