 fAlbedoTexture:=-1;
 fNormalTexture:=-1;
 fORMTexture:=-1;
 fSpecularTexture:=-1;
 fEmissiveTexture:=-1;
 fLifetime:=-1.0; // Infinite lifetime by default
 fFadeOutTime:=0.0;
