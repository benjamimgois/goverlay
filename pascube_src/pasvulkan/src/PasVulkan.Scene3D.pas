     end else begin
      inc(Index);
     end;
    end;
   end;
  end;
  3:begin
   if Channel.fInterpolation=TpvScene3D.TGroup.TAnimation.TChannel.TInterpolation.CubicSpline then begin
    SetLength(Channel.fOutputVector3Array,fCount*3);
