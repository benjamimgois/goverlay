  fPreviousActive:=true;

 end else if fPreviousActive then begin

  if aInFlightFrameIndex>=0 then begin
   fActiveScenes[aInFlightFrameIndex]:=nil;
  end;

  if fAABBTreeProxy>=0 then begin
   try
    if assigned(fGroup) and
