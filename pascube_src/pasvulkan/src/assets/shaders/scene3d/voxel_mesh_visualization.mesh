#version 460 core

// Mesh-shader variant of the voxel mesh visualization (used when MeshShaderSupport and MeshShaderPipelineActive are on).
// One workgroup per voxel (3D dispatch: gl_WorkGroupID.xyz = voxel grid position, avoids the per-dimension workgroup-count
// limit a flat gridSize^3 dispatch would hit). Reads the 6 anisotropic-direction radiance texels of the voxel; if all empty the
// workgroup emits nothing (GPU-side cull of empty voxels), otherwise it emits a cube (6 faces x 4 verts + 12 triangles) with the
// per-face anisotropic colour. Matches voxel_visualization / the vertex path's resolved-radiance look; the raw-content diagnostic
// stays on the vertex path. The fragment shader (voxel_mesh_visualization.frag) is shared (inColor @ location 0).

#extension GL_EXT_mesh_shader : enable
#extension GL_EXT_multiview : enable
#extension GL_GOOGLE_include_directive : enable
#extension GL_EXT_nonuniform_qualifier : enable

/* clang-format off */

layout(local_size_x = 1, local_size_y = 1, local_size_z = 1) in;
layout(triangles, max_vertices = 24, max_primitives = 12) out;

layout(push_constant) uniform PushConstants {
  uint viewBaseIndex;
  uint countViews;
  uint gridSizeBits;
  uint cascadeIndex;
} pushConstants;

struct View {
  mat4 viewMatrix;
  mat4 projectionMatrix;
  mat4 inverseViewMatrix;
  mat4 inverseProjectionMatrix;
};

layout(set = 0, binding = 0, std140) uniform uboViews {
  View views[256];
} uView;

layout(set = 1, binding = 0, std140) readonly uniform VoxelGridData {
  #include "voxelgriddata_uniforms.glsl"
} voxelGridData;

layout(set = 1, binding = 1) uniform sampler3D uVoxelGridOcclusion[];
layout(set = 1, binding = 2) uniform sampler3D uVoxelGridRadiance[];
// Unlit base-colour + emission visualization volume (E5B9G9R9 sample view), filled while the debug visualization is active.
layout(set = 1, binding = 3) uniform sampler3D uVoxelGridVisualization[];

layout(location = 0) out vec4 outColor[];

void main(){

  uint cascadeIndex = pushConstants.cascadeIndex;
  ivec3 voxelPosition = ivec3(gl_WorkGroupID.xyz);

  // Coarser cascades skip voxels inside a finer cascade's region (same test as the vertex path).
  bool valid = (cascadeIndex == 0u) ||
               !(all(greaterThanEqual(voxelPosition, voxelGridData.cascadeAvoidAABBGridMin[cascadeIndex].xyz)) &&
                 all(lessThan(voxelPosition, voxelGridData.cascadeAvoidAABBGridMax[cascadeIndex].xyz)));

  vec4 sideColors[6];
  vec4 anyColor = vec4(0.0);
  for(uint side = 0u; side < 6u; side++){
    sideColors[side] = valid ? texelFetch(uVoxelGridVisualization[(cascadeIndex * 6u) + side], voxelPosition, 0) : vec4(0.0);
    anyColor += sideColors[side];
  }

  // Empty voxel -> emit nothing (GPU-side cull, the win over the vertex path which still processes degenerate cube vertices).
  // The E5B9G9R9 sample has no alpha (always 1.0), so emptiness must be tested on rgb only.
  if(dot(anyColor.xyz, anyColor.xyz) <= 0.0){
    SetMeshOutputsEXT(0u, 0u);
    return;
  }

  SetMeshOutputsEXT(24u, 12u);

  const ivec3 vertices[8] = ivec3[8](
    ivec3(0, 0, 0), ivec3(1, 0, 0), ivec3(0, 1, 0), ivec3(1, 1, 0),
    ivec3(0, 0, 1), ivec3(1, 0, 1), ivec3(0, 1, 1), ivec3(1, 1, 1)
  );
  const ivec4 quadIndicesArray[6] = ivec4[6](
    ivec4(1, 5, 7, 3), // +X
    ivec4(2, 3, 7, 6), // +Y
    ivec4(4, 6, 7, 5), // +Z
    ivec4(0, 2, 6, 4), // -X
    ivec4(0, 4, 5, 1), // -Y
    ivec4(0, 1, 3, 2)  // -Z
  );

  uint viewIndex = pushConstants.viewBaseIndex + uint(gl_ViewIndex);
  mat4 viewProjectionMatrix = uView.views[viewIndex].projectionMatrix * uView.views[viewIndex].viewMatrix;
  float cellSize = voxelGridData.cascadeCellSizes[cascadeIndex >> 2u][cascadeIndex & 3u];
  vec3 aabbMin = voxelGridData.cascadeAABBMin[cascadeIndex].xyz;

  for(uint face = 0u; face < 6u; face++){
    vec4 faceColor = sideColors[face];
    for(uint corner = 0u; corner < 4u; corner++){
      uint vertexIndex = (face * 4u) + corner;
      ivec3 cornerPosition = voxelPosition + vertices[quadIndicesArray[face][corner]];
      gl_MeshVerticesEXT[vertexIndex].gl_Position = viewProjectionMatrix * vec4(fma(vec3(cornerPosition), vec3(cellSize), aabbMin), 1.0);
      outColor[vertexIndex] = faceColor;
    }
    gl_PrimitiveTriangleIndicesEXT[(face * 2u) + 0u] = uvec3((face * 4u) + 0u, (face * 4u) + 1u, (face * 4u) + 2u);
    gl_PrimitiveTriangleIndicesEXT[(face * 2u) + 1u] = uvec3((face * 4u) + 0u, (face * 4u) + 2u, (face * 4u) + 3u);
  }

}
