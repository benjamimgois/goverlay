#version 460

#pragma shader_stage(mesh)

#extension GL_EXT_mesh_shader : enable
#ifdef MULTIVIEW
  #extension GL_EXT_multiview : enable
#endif
#extension GL_ARB_separate_shader_objects : enable
#extension GL_ARB_shading_language_420pack : enable
#extension GL_GOOGLE_include_directive : enable
#extension GL_EXT_nonuniform_qualifier : enable
#extension GL_EXT_control_flow_attributes : enable

#define MESH_GROUP_SIZE 128

layout(local_size_x = MESH_GROUP_SIZE, local_size_y = 1, local_size_z = 1) in;
layout(triangles, max_vertices = 81, max_primitives = 128) out;

#include "bufferreference_definitions.glsl"
#include "planet_terrain.glsl"
#include "octahedral.glsl"

#if defined(RAYTRACING)
layout(set = 0, binding = 10) uniform sampler2D u2DTextures[];
#else
layout(set = 0, binding = 8) uniform sampler2D u2DTextures[];
#endif

#include "planet_displacement.glsl"

#define PASS_DESCRIPTOR_SET 1
#define TERRAIN_MESH_DESCRIPTOR_SET 3

struct View {
  mat4 viewMatrix;
  mat4 projectionMatrix;
  mat4 inverseViewMatrix;
  mat4 inverseProjectionMatrix;
};

layout(set = PASS_DESCRIPTOR_SET, binding = 0, std140) uniform uboViews {
  View views[256];
} uView;

layout(set = TERRAIN_MESH_DESCRIPTOR_SET, binding = 0, std430) readonly buffer VisualMeshVertices {
  uvec4 vertices[];
} visualMeshVertices;

struct TaskData {
  uint tileIndex;
  uint lodLevel; // 0=full detail, 1=half, 2=quarter; stride = 1<<lodLevel
};
taskPayloadSharedEXT TaskData taskData;

#if defined(RAYTRACING)

layout(location = 0) out vec3 outWorldSpacePosition[];
layout(location = 1) flat out vec3 outCameraPosition[];
layout(location = 2) out OutBlock {
  vec3 position;
  vec3 sphereNormal;
  vec3 normal;
  vec3 triplanarNormal;
  vec3 triplanarPosition;
  vec3 viewSpacePosition;
  flat uint meshletID;
#ifdef VELOCITY
  vec4 previousClipSpace;
  vec4 currentClipSpace;
#endif
} outBlock[];

#else

layout(location = 0) out OutBlock {
  vec3 position;
  vec3 sphereNormal;
  vec3 normal;
  vec3 triplanarNormal;
  vec3 triplanarPosition;
  vec3 worldSpacePosition;
  vec3 viewSpacePosition;
  vec3 cameraRelativePosition;
  flat uint meshletID;
#ifdef VELOCITY
  vec4 previousClipSpace;
  vec4 currentClipSpace;
#endif
} outBlock[];

#endif // defined(RAYTRACING)

#if defined(MULTIVIEW)
uint viewIndex = pushConstants.viewBaseIndex + uint(gl_ViewIndex);
#else
uint viewIndex = pushConstants.viewBaseIndex;
#endif

void main() {

  const uint MESHLET_K_PLUS_1 = MESHLET_K + 1u;

  uint tileRes = planetData.flagsResolutions.y & 0xFFFFu;
  uint tileMapRes = (planetData.flagsResolutions.y >> 16u) & 0xFFFFu;
  uint totalRes = tileRes * tileMapRes;
  uint totalResMask = totalRes - 1u; // valid since totalRes is power-of-2
  uint tileX = taskData.tileIndex % tileMapRes;
  uint tileY = taskData.tileIndex / tileMapRes;
  uint lodStride = 1u << taskData.lodLevel;
  uint meshletsPerSide = tileRes / (MESHLET_K * lodStride);
  uint meshletLocalX = gl_WorkGroupID.x % meshletsPerSide;
  uint meshletLocalY = gl_WorkGroupID.x / meshletsPerSide;
  uint meshletBaseX = meshletLocalX * MESHLET_K * lodStride;
  uint meshletBaseY = meshletLocalY * MESHLET_K * lodStride;

  SetMeshOutputsEXT(MESHLET_VERT_COUNT, MESHLET_PRIM_COUNT);

  mat4 viewMatrix = uView.views[viewIndex].viewMatrix;
  mat4 projectionMatrix = uView.views[viewIndex].projectionMatrix;
  mat4 inverseViewMatrix = uView.views[viewIndex].inverseViewMatrix;
  mat4 viewProjectionMatrix = projectionMatrix * viewMatrix;

  vec3 cameraPosition = inverseViewMatrix[3].xyz;

  uint threadIdx = gl_LocalInvocationIndex;

  // Vertex processing: MESHLET_VERT_COUNT = (K+1)^2 = 81 vertices, threads 0..80 each handle one vertex
  if (threadIdx < MESHLET_VERT_COUNT) {
    uint localX = threadIdx % MESHLET_K_PLUS_1;
    uint localY = threadIdx / MESHLET_K_PLUS_1;
    uint globalX = meshletBaseX + (localX * lodStride);
    uint globalY = meshletBaseY + (localY * lodStride);
    // GetVertexIndex equivalent: handle tile-seam wrap-around (octahedral sphere)
    uint absX = (tileX * tileRes) + globalX;
    uint absY = (tileY * tileRes) + globalY;
    uint wx = absX & totalResMask;
    uint wy = absY & totalResMask;
    uint divX = absX / totalRes; // 0 or 1; 1 only at the seam (last tile wraps)
    uint divY = absY / totalRes;
    if (((divX ^ divY) & 1u) != 0u) {
      wx = (totalRes - (wx + 1u)) & totalResMask;
      wy = (totalRes - (wy + 1u)) & totalResMask;
    }
    uint atX = wx / tileRes;
    uint atY = wy / tileRes;
    uint lvX = wx - atX * tileRes;
    uint lvY = wy - atY * tileRes;
    uint vtxIdx = (atY * tileMapRes + atX) * tileRes * tileRes + lvY * tileRes + lvX;

    uvec4 vd = visualMeshVertices.vertices[vtxIdx];
    vec3 inVector = uintBitsToFloat(vd.xyz);
    vec2 encodedNormal = unpackSnorm2x16(vd.w);

    vec3 sphereNormal = normalize(inVector);
    vec3 position = (planetData.modelMatrix * vec4(inVector, 1.0)).xyz;
    vec3 triplanarPosition = (planetData.triplanarMatrix * vec4(inVector, 1.0)).xyz;
    vec3 worldSpacePosition = position;

    vec3 normal = octSignedDecode(encodedNormal);
    if((planetData.flagsResolutions.x & (1u << 1u)) != 0u){
      layerMaterialSetup(sphereNormal);
      multiplanarSetup(position, vec3(1e-6), vec3(1e-6), normal);
      float displacement = 1.0 - clamp(getLayeredMultiplanarHeight(), 0.0, 1.0);
      position -= normal * displacement * 0.25;
    }

    vec4 viewSpacePositionH = viewMatrix * vec4(position, 1.0);
    viewSpacePositionH.xyz /= viewSpacePositionH.w;

    outBlock[threadIdx].position = position;
    outBlock[threadIdx].sphereNormal = sphereNormal;
    outBlock[threadIdx].normal = normalize((planetData.normalMatrix * vec4(normal, 0.0)).xyz);
    outBlock[threadIdx].triplanarNormal = normalize((planetData.triplanarNormalMatrix * vec4(normal, 0.0)).xyz);
    outBlock[threadIdx].triplanarPosition = triplanarPosition;
    outBlock[threadIdx].viewSpacePosition = viewSpacePositionH.xyz;
    outBlock[threadIdx].meshletID = ((pushConstants.flags & (1u << PLANET_TERRAIN_FLAG_MESHLET_DEBUG_COLORS)) != 0u)
                                    ? (((taskData.tileIndex * (meshletsPerSide * meshletsPerSide)) + gl_WorkGroupID.x) | 0x80000000u)
                                    : 0u;

#if defined(RAYTRACING)
    outWorldSpacePosition[threadIdx] = worldSpacePosition;
    outCameraPosition[threadIdx] = cameraPosition;
#else
    outBlock[threadIdx].worldSpacePosition = worldSpacePosition;
    outBlock[threadIdx].cameraRelativePosition = worldSpacePosition - cameraPosition;
#endif

#ifdef VELOCITY
    outBlock[threadIdx].currentClipSpace = viewProjectionMatrix * vec4(position, 1.0);
    outBlock[threadIdx].previousClipSpace = (uView.views[viewIndex + pushConstants.countAllViews].projectionMatrix * uView.views[viewIndex + pushConstants.countAllViews].viewMatrix) * vec4(position, 1.0);
#endif

    gl_MeshVerticesEXT[threadIdx].gl_Position = viewProjectionMatrix * vec4(position, 1.0);
  }

  // Primitive processing: MESHLET_PRIM_COUNT = K*K*2 = 128 primitives, all 128 threads each handle one primitive
  // MAYBE-TODO: per-primitive back-face culling (via gl_MeshPrimitiveCullEXT or degenerate index)
  //   PRO:  eliminates back-facing triangles before rasterization, ~save at horizon/grazing angles
  //   CON:  HW rasterizer already culls back-faces cheaply; back-side tiles already culled by task
  //         shader; curvature per meshlet is tiny (large planet) => almost no back-faces inside a
  //         visible meshlet; needs shared memory to read vertex positions in primitive threads.
  //   VERDICT: overhead > gain for planet terrain -- skip unless profiling shows otherwise.
  {
    uint primIdx = threadIdx;
    uint quadIdx = primIdx >> 1u;
    uint qx = quadIdx % MESHLET_K;
    uint qy = quadIdx / MESHLET_K;
    bool second = (primIdx & 1u) != 0u;
    uint i00 = (qy * MESHLET_K_PLUS_1) + qx;
    uint i10 = (qy * MESHLET_K_PLUS_1) + (qx + 1u);
    uint i01 = ((qy + 1u) * MESHLET_K_PLUS_1) + qx;
    uint i11 = ((qy + 1u) * MESHLET_K_PLUS_1) + (qx + 1u);
    if (second) {
      gl_PrimitiveTriangleIndicesEXT[primIdx] = uvec3(i10, i11, i01);
    } else {
      gl_PrimitiveTriangleIndicesEXT[primIdx] = uvec3(i00, i10, i01);
    }
  }

}
