#version 460

#pragma shader_stage(mesh)

#extension GL_EXT_mesh_shader : enable
#ifdef MULTIVIEW
  #extension GL_EXT_multiview : enable
#endif
#extension GL_ARB_separate_shader_objects : enable
#extension GL_ARB_shading_language_420pack : enable
#extension GL_GOOGLE_include_directive : enable
#extension GL_EXT_nonuniform_qualifier : enable
#extension GL_EXT_control_flow_attributes : enable

// K=8: vertices=(K+1)^2=81, primitives=K*K*2=128
#define MESHLET_K 8u
#define MESHLET_K_PLUS_1 (MESHLET_K + 1u)
#define MESHLET_VERT_COUNT 81   // (K+1)^2
#define MESHLET_PRIM_COUNT 128  // K*K*2
#define MESH_GROUP_SIZE 128

layout(local_size_x = MESH_GROUP_SIZE, local_size_y = 1, local_size_z = 1) in;
layout(triangles, max_vertices = MESHLET_VERT_COUNT, max_primitives = MESHLET_PRIM_COUNT) out;

#include "bufferreference_definitions.glsl"

#define USE_PLANET_BUFFER_REFERENCE
#include "planet_data.glsl"

#define PLANET_WATER
#include "planet_renderpass.glsl"

#include "octahedral.glsl"
#include "octahedralmap.glsl"

#if defined(RAYTRACING)
layout(set = 0, binding = 10) uniform sampler2D u2DTextures[];
#else
layout(set = 0, binding = 8) uniform sampler2D u2DTextures[];
#endif

#define PASS_DESCRIPTOR_SET 1
#define PLANET_DESCRIPTOR_SET 2

struct View {
  mat4 viewMatrix;
  mat4 projectionMatrix;
  mat4 inverseViewMatrix;
  mat4 inverseProjectionMatrix;
};

layout(set = PASS_DESCRIPTOR_SET, binding = 0, std140) uniform uboViews {
  View views[256];
} uView;

layout(set = PLANET_DESCRIPTOR_SET, binding = 0) uniform sampler2D uPlanetTextures[];
layout(set = PLANET_DESCRIPTOR_SET, binding = 0) uniform sampler2DArray uPlanetArrayTextures[];

#include "planet_textures.glsl"

// Required globals for planet_water.glsl
vec3 planetCenter = vec3(0.0);
float planetBottomRadius = planetData.bottomRadiusTopRadiusHeightMapScale.x;
float planetTopRadius = planetData.bottomRadiusTopRadiusHeightMapScale.y;
mat4 planetModelMatrix = planetData.modelMatrix;
mat4 planetInverseModelMatrix = inverse(planetModelMatrix);

#include "planet_water.glsl"

struct TaskData {
  uint quadIndex;
  uint meshletsPerSide;
};
taskPayloadSharedEXT TaskData taskData;

layout(location = 0) out OutBlock {
  vec3 localPosition;
  vec3 position;
  vec3 sphereNormal;
  vec3 normal;
  vec3 worldSpacePosition;
  vec3 viewSpacePosition;
  vec3 cameraRelativePosition;
  float mapValue;
  float waterOverSurface;
  float underWater;
  flat uint meshletID;
} outBlock[];

#if defined(MULTIVIEW)
uint viewIndex = pushConstants.viewBaseIndex + uint(gl_ViewIndex);
#else
uint viewIndex = pushConstants.viewBaseIndex;
#endif

shared bool sharedUnderWater;

void main() {

  uint countQ = pushConstants.countQuadPointsInOneDirection;
  uint M = taskData.meshletsPerSide;
  uint quadIndex = taskData.quadIndex;
  uint quadX = quadIndex % countQ;
  uint quadY = quadIndex / countQ;

  // Which meshlet within this quad
  uint mx = gl_WorkGroupID.x % M;
  uint my = gl_WorkGroupID.x / M;

  SetMeshOutputsEXT(MESHLET_VERT_COUNT, MESHLET_PRIM_COUNT);

  mat4 viewMatrix = uView.views[viewIndex].viewMatrix;
  mat4 projectionMatrix = uView.views[viewIndex].projectionMatrix;
  mat4 inverseViewMatrix = uView.views[viewIndex].inverseViewMatrix;
  mat4 viewProjectionMatrix = projectionMatrix * viewMatrix;
  vec3 cameraPosition = inverseViewMatrix[3].xyz;

  // Compute underwater state once per thread group (thread 0 only), then broadcast via shared memory
  uint threadIdx = gl_LocalInvocationIndex;
  if(threadIdx == 0u) {
    vec3 planetSpaceCameraPos = (planetInverseModelMatrix * vec4(cameraPosition, 1.0)).xyz;
    sharedUnderWater = map(planetSpaceCameraPos) <= 0.0;
  }
  barrier();
  bool underWater = sharedUnderWater;

  // Compute meshlet debug ID
  #define PLANET_WATER_FLAG_MESHLET_DEBUG_COLORS 3u
  uint meshletGlobalID = taskData.quadIndex * (M * M) + gl_WorkGroupID.x;
  uint meshletIDOut = ((pushConstants.flags & (1u << PLANET_WATER_FLAG_MESHLET_DEBUG_COLORS)) != 0u) ? (meshletGlobalID | 0x80000000u) : 0u;

  // Vertex processing: 81 vertices, threads 0..80 each handle one vertex
  if (threadIdx < MESHLET_VERT_COUNT) {
    uint localX = threadIdx % MESHLET_K_PLUS_1;
    uint localY = threadIdx / MESHLET_K_PLUS_1;

    // Global position in the full countQ*M*K grid
    uint totalK = countQ * M * MESHLET_K;
    uint globalX = ((quadX * M * MESHLET_K) + (mx * MESHLET_K)) + localX;
    uint globalY = ((quadY * M * MESHLET_K) + (my * MESHLET_K)) + localY;
    vec2 uv = vec2(globalX, globalY) / float(totalK);

    vec3 sphereNormal = octPlanetUnsignedDecode(uv);

    vec2 sphereHeightData = getSphereHeightData(sphereNormal);
    float sphereHeight = dot(sphereHeightData, vec2(1.0));

    // Wave height displacement: UV chop (computeWaveDisplacement) + Gerstner swell (computeGerstnerDisplacement).
    // Only applied where water is present (sphereHeightData.y > 1e-6).
    if(sphereHeightData.y > 1e-6){
      vec4 dp0 = vec4(unpackHalf2x16(planetData.waterDisplaceParams.x), unpackHalf2x16(planetData.waterDisplaceParams.y));
      float displaceAmpl = dp0.x;
      vec4 wvp0 = vec4(unpackHalf2x16(planetData.waterWaveParams.x), unpackHalf2x16(planetData.waterWaveParams.y));
      vec4 wvp1 = vec4(unpackHalf2x16(planetData.waterWaveParams.z), unpackHalf2x16(planetData.waterWaveParams.w));
      float gerstnerAmpl = wvp0.w;
      if((displaceAmpl > 0.0) || (gerstnerAmpl > 0.0)){
        float displacementFactor = smoothstep(dp0.y, dp0.z, sphereHeightData.y) * dp0.w;
        if(displacementFactor > 0.0){
          float waveH = 0.0;
          if(displaceAmpl > 0.0){
            vec4 uvwp0 = vec4(unpackHalf2x16(planetData.waterUVWaveParams.x), unpackHalf2x16(planetData.waterUVWaveParams.y));
            vec4 uvwp1 = vec4(unpackHalf2x16(planetData.waterUVWaveParams.z), unpackHalf2x16(planetData.waterUVWaveParams.w));
            waveH += computeWaveDisplacement(uv, pushConstants.time, uvwp0.y, uvwp0.z, uvwp1.z) * displaceAmpl * displacementFactor;
          }
          if(gerstnerAmpl > 0.0){
            vec3 windDir = wvp0.xyz;
            float wdL = length(windDir);
            if(wdL > 1e-3){ windDir /= wdL; }
            waveH += computeGerstnerDisplacement(sphereNormal * sphereHeight, windDir, wvp1.x, wvp1.z, wvp1.y, pushConstants.time) * gerstnerAmpl * displacementFactor;
          }
          sphereHeight = clamp(sphereHeight + waveH, planetData.bottomRadiusTopRadiusHeightMapScale.x * 0.5, planetData.bottomRadiusTopRadiusHeightMapScale.y);
        }
      }
    }

    vec3 localPosition = sphereNormal * ((sphereHeight > 1e-6) ? clamp(sphereHeight, planetData.bottomRadiusTopRadiusHeightMapScale.x * 0.5, planetData.bottomRadiusTopRadiusHeightMapScale.y) : 1e-6);

    vec3 position = (planetData.modelMatrix * vec4(localPosition, 1.0)).xyz;
    vec3 worldSpacePosition = position;
    vec3 normal = sphereNormal;

    vec4 viewSpacePositionH = viewMatrix * vec4(position, 1.0);
    viewSpacePositionH.xyz /= viewSpacePositionH.w;

    outBlock[threadIdx].localPosition = localPosition;
    outBlock[threadIdx].position = position;
    outBlock[threadIdx].sphereNormal = sphereNormal;
    outBlock[threadIdx].normal = normalize((planetData.normalMatrix * vec4(normal, 0.0)).xyz);
    outBlock[threadIdx].worldSpacePosition = worldSpacePosition;
    outBlock[threadIdx].viewSpacePosition = viewSpacePositionH.xyz;
    outBlock[threadIdx].cameraRelativePosition = worldSpacePosition - cameraPosition;
    outBlock[threadIdx].mapValue = mapHeight(localPosition, sphereHeight);
    outBlock[threadIdx].waterOverSurface = (sphereHeightData.y > 1e-6) ? 1.0 : 0.0;
    outBlock[threadIdx].underWater = underWater ? 1.0 : 0.0;
    outBlock[threadIdx].meshletID = meshletIDOut;

    gl_MeshVerticesEXT[threadIdx].gl_Position = viewProjectionMatrix * vec4(position, 1.0);
  }

  // Primitive processing: 128 primitives
  {
    uint primIdx = threadIdx;
    uint quadIdx = primIdx >> 1u;
    uint qx = quadIdx % MESHLET_K;
    uint qy = quadIdx / MESHLET_K;
    bool second = (primIdx & 1u) != 0u;
    uint i00 = (qy * MESHLET_K_PLUS_1) + qx;
    uint i10 = (qy * MESHLET_K_PLUS_1) + (qx + 1u);
    uint i01 = ((qy + 1u) * MESHLET_K_PLUS_1) + qx;
    uint i11 = ((qy + 1u) * MESHLET_K_PLUS_1) + (qx + 1u);
    if (second) {
      gl_PrimitiveTriangleIndicesEXT[primIdx] = uvec3(i10, i11, i01);
    } else {
      gl_PrimitiveTriangleIndicesEXT[primIdx] = uvec3(i00, i10, i01);
    }
  }

}
